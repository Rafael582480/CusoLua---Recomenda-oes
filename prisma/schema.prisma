generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")  // ← ADICIONE ESTA LINHA
}

model Code {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  nome        String  @default("Desafio sem nome")
  result      String 
  description String
  code_base   String
  codes       Codes?  @relation(fields: [codesId], references: [id])
  codesId     String? @db.ObjectId
}

model Codes {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  Codes Code[]
}